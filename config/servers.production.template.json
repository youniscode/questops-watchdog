{
  "productName": "QuestOps Watchdog",
  "configVersion": 1,

  "global": {
    "checkIntervalMinutes": 5,
    "logDateFormat": "yyyy-MM-dd HH:mm:ss",
    "stateDir": ".\\state",
    "logDir": ".\\logs"
  },

  "discord": {
    "webhookUrlEnvVar": "QUESTOPS_DISCORD_WEBHOOK",
    "enabled": false,
    "defaultCooldownMinutes": 30
  },

  "summary": {
    "enabled": false,
    "sendOnlyOnIssues": true,
    "includeHealthyServers": false,
    "cooldownMinutes": 30
  },

  "servers": [
    {
      "name": "Valheim",
      "category": "survival",
      "tags": ["valheim", "survival", "viking"],
      "enabled": false,
      "notes": "REPLACE paths below with your Valheim server install location.",

      "process": {
        "name": "valheim_server.exe",
        "enabled": true
      },

      "logFile": {
        "path": "C:\\REPLACE_ME\\Valheim\\logs",
        "maxAgeMinutes": 30,
        "enabled": true
      },

      "disk": {
        "path": "C:\\",
        "minFreeGB": 20,
        "enabled": true
      },

      "backup": {
        "path": "C:\\REPLACE_ME\\Valheim\\backups",
        "maxAgeHours": 48,
        "enabled": true
      },

      "maintenance": {
        "enabled": false,
        "flagPath": ".\\state\\maintenance\\valheim.flag",
        "suppressAlerts": true
      },

      "discord": {
        "webhookUrlEnvVar": "QUESTOPS_DISCORD_WEBHOOK",
        "cooldownMinutes": 30
      }
    },

    {
      "name": "Project Zomboid",
      "category": "survival",
      "tags": ["zomboid", "survival", "zombie"],
      "enabled": false,
      "notes": "REPLACE paths below with your Project Zomboid server install location.",

      "process": {
        "name": "ProjectZomboid64.exe",
        "enabled": true
      },

      "logFile": {
        "path": "C:\\REPLACE_ME\\Zomboid\\logs",
        "maxAgeMinutes": 30,
        "enabled": true
      },

      "disk": {
        "path": "C:\\",
        "minFreeGB": 20,
        "enabled": true
      },

      "backup": {
        "path": "C:\\REPLACE_ME\\Zomboid\\backups",
        "maxAgeHours": 48,
        "enabled": true
      },

      "maintenance": {
        "enabled": false,
        "flagPath": ".\\state\\maintenance\\zomboid.flag",
        "suppressAlerts": true
      },

      "discord": {
        "webhookUrlEnvVar": "QUESTOPS_DISCORD_WEBHOOK",
        "cooldownMinutes": 30
      }
    },

    {
      "name": "Minecraft",
      "category": "sandbox",
      "tags": ["minecraft", "sandbox", "java"],
      "enabled": false,
      "notes": "REPLACE paths below with your Minecraft server install location. Process is typically java.exe for vanilla servers.",

      "process": {
        "name": "java.exe",
        "enabled": true
      },

      "logFile": {
        "path": "C:\\REPLACE_ME\\Minecraft\\logs",
        "maxAgeMinutes": 30,
        "enabled": true
      },

      "disk": {
        "path": "C:\\",
        "minFreeGB": 20,
        "enabled": true
      },

      "backup": {
        "path": "C:\\REPLACE_ME\\Minecraft\\backups",
        "maxAgeHours": 48,
        "enabled": true
      },

      "maintenance": {
        "enabled": false,
        "flagPath": ".\\state\\maintenance\\minecraft.flag",
        "suppressAlerts": true
      },

      "discord": {
        "webhookUrlEnvVar": "QUESTOPS_DISCORD_WEBHOOK",
        "cooldownMinutes": 30
      }
    },

    {
      "name": "ICARUS",
      "category": "survival",
      "tags": ["icarus", "survival", "openworld"],
      "enabled": false,
      "notes": "REPLACE paths below with your ICARUS dedicated server install location.",

      "process": {
        "name": "IcarusServer-Win64-Shipping.exe",
        "enabled": true
      },

      "logFile": {
        "path": "C:\\REPLACE_ME\\ICARUS\\logs",
        "maxAgeMinutes": 45,
        "enabled": true
      },

      "disk": {
        "path": "C:\\",
        "minFreeGB": 20,
        "enabled": true
      },

      "backup": {
        "path": "C:\\REPLACE_ME\\ICARUS\\backups",
        "maxAgeHours": 48,
        "enabled": true
      },

      "maintenance": {
        "enabled": false,
        "flagPath": ".\\state\\maintenance\\icarus.flag",
        "suppressAlerts": true
      },

      "discord": {
        "webhookUrlEnvVar": "QUESTOPS_DISCORD_WEBHOOK",
        "cooldownMinutes": 30
      }
    },

    {
      "name": "7 Days to Die",
      "category": "survival",
      "tags": ["7days", "survival", "zombie"],
      "enabled": false,
      "notes": "REPLACE paths below with your 7 Days to Die dedicated server install location.",

      "process": {
        "name": "7DaysToDieServer.exe",
        "enabled": true
      },

      "logFile": {
        "path": "C:\\REPLACE_ME\\7DaysToDie\\logs",
        "maxAgeMinutes": 30,
        "enabled": true
      },

      "disk": {
        "path": "C:\\",
        "minFreeGB": 20,
        "enabled": true
      },

      "backup": {
        "path": "C:\\REPLACE_ME\\7DaysToDie\\backups",
        "maxAgeHours": 48,
        "enabled": true
      },

      "maintenance": {
        "enabled": false,
        "flagPath": ".\\state\\maintenance\\7days.flag",
        "suppressAlerts": true
      },

      "discord": {
        "webhookUrlEnvVar": "QUESTOPS_DISCORD_WEBHOOK",
        "cooldownMinutes": 30
      }
    },

    {
      "name": "Windrose",
      "category": "mmo",
      "tags": ["windrose", "mmo", "openworld"],
      "enabled": false,
      "notes": "REPLACE paths below with your Windrose server install location.",

      "process": {
        "name": "WindroseServer.exe",
        "enabled": true
      },

      "logFile": {
        "path": "C:\\REPLACE_ME\\Windrose\\logs",
        "maxAgeMinutes": 45,
        "enabled": true
      },

      "disk": {
        "path": "C:\\",
        "minFreeGB": 20,
        "enabled": true
      },

      "backup": {
        "path": "C:\\REPLACE_ME\\Windrose\\backups",
        "maxAgeHours": 48,
        "enabled": true
      },

      "maintenance": {
        "enabled": false,
        "flagPath": ".\\state\\maintenance\\windrose.flag",
        "suppressAlerts": true
      },

      "discord": {
        "webhookUrlEnvVar": "QUESTOPS_DISCORD_WEBHOOK",
